# .env — INTENTIONALLY DIRTY.
# This file mimics what a developer might accidentally commit. It exists
# only to exercise the secret scanner; do NOT use these values for anything.
#
# This file is in .gitignore but still readable from disk so the
# extension can demonstrate redaction on chat requests that reference
# it (e.g. via @-mentions in a Copilot prompt).

PORT=8080
DEBUG=true

# AWS access key (AKIA prefix → aws-access-token rule)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# GitHub Personal Access Token (ghp_ prefix → github-pat rule)
GITHUB_TOKEN=ghp_AbCdEfGhIjKlMnOpQrStUvWxYz0123456789

# Slack bot token (xoxb- → slack-access-token rule)
SLACK_BOT_TOKEN=xoxb-123456789012-1234567890123-abcdefghijklmnopqrstuvwx

# OpenAI key (sk- prefix + 48 chars → openai-api-key rule)
OPENAI_API_KEY=sk-proj-abcdefghijklmnopqrstuvwxyz0123456789ABCDEFGHIJKLMN

# A JWT that would be flagged by the generic-high-entropy rule
JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyXzEyMyIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoxOTAwMDAwMDAwfQ.signature_part_here
