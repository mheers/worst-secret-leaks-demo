# .env — INTENTIONALLY DIRTY.
# This file mimics what a developer might accidentally commit. It exists
# only to exercise the secret scanner; do NOT use these values for anything.
#
# This file is in .gitignore but still readable from disk so the
# extension can demonstrate redaction on chat requests that reference
# it (e.g. via @-mentions in a Copilot prompt).

PORT=8080
DEBUG=true

# AWS access key (AKIA prefix → aws-access-token rule; the key MUST NOT
# end in `EXAMPLE` — trufflehog skips those as a built-in false positive)
AWS_ACCESS_KEY_ID=AKIA4N7SI2K8X9Y3QZWP
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMIK7MDENGbPxRfiCY7x9q2Zr4wKxY

# GitHub Personal Access Token (ghp_ prefix → github-pat rule)
# High-entropy suffix ensures trufflehog's Github detector fires.
GITHUB_TOKEN=ghp_M7p9Lq3RtV34X7K2H8Q5N1B6J0Z9D4Y7S2P8

# Slack bot token (xoxb- → slack-access-token rule)
SLACK_BOT_TOKEN=xoxb-123456789012-1234567890123-aBc3fGh5jKl7mNo9qRs2uVwX

# OpenAI key (sk-proj- prefix + 48+ chars → openai-api-key rule)
OPENAI_API_KEY=sk-proj-Xy9zA1bC2dE3fG4hT3BlbkFJ5I6J7K8L9M0N1O2P3Q4R5S6T

# A JWT that would be flagged by the generic-high-entropy rule
JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ1c2VyXzEyMyIsImlhdCI6MTcwMDAwMDAwMCwiZXhwIjoxOTAwMDAwMDAwfQ.x9QzJ7n5Q8Lw2KpR4vYsT6Bc1Ae3DgFh5Jm0KlNoPqR
