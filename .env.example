# Example env file with NO real secrets.
# Use this as a template — copy to .env and fill in real values locally.
# This file MUST NOT contain real credentials so it can be checked in.

PORT=8080
DEBUG=false

# Public-safe placeholders only. The values below are intentionally
# non-secret: low entropy, well-known test strings, or empty.
DATABASE_URL=postgres://demo:demo@localhost:5432/demo
JWT_SECRET=replace-me-in-production
STRIPE_SECRET_KEY=
SLACK_BOT_TOKEN=
OPENAI_API_KEY=
SENTRY_DSN=
LISTEN_ADDR=:8080
